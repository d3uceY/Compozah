/* ============================================================
   Compozah Dashboard Styles - Generated by Compozah
   ============================================================ */

:root {
    --color-bg: #0f172a;
    --color-surface: #1e293b;
    --color-surface-hover: #334155;
    --color-border: #334155;
    --color-text: #f1f5f9;
    --color-text-muted: #94a3b8;
    --color-primary: #3b82f6;
    --color-primary-hover: #2563eb;
    --color-accent: #10b981;
    --color-warning: #f59e0b;
    --color-danger: #ef4444;
    --radius: 12px;
    --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -2px rgba(0, 0, 0, 0.3);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    min-height: 100vh;
    line-height: 1.6;
}

/* --- Header --- */

.dashboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
}

.dashboard-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
}

.header-info {
    display: flex;
    gap: 16px;
    align-items: center;
    font-size: 0.875rem;
    color: var(--color-text-muted);
}

.refresh-timer {
    background: var(--color-primary);
    color: white;
    padding: 4px 12px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.75rem;
}

/* --- Dashboard Grid --- */

.dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
    padding: 24px 32px;
    max-width: 1600px;
    margin: 0 auto;
}

/* --- Widget Card --- */

.widget-card {
    background: var(--color-surface);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
}

.widget-card:hover {
    border-color: var(--color-primary);
}

.widget-card.wide {
    grid-column: span 2;
}

.widget-card.full {
    grid-column: 1 / -1;
}

.widget-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
}

.widget-header h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.widget-body {
    padding: 20px;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
}

/* --- KPI Number Widget --- */

.kpi-number {
    text-align: center;
}

.kpi-number .kpi-value {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1.2;
}

.kpi-number .kpi-unit {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-left: 8px;
}

.kpi-number .kpi-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 4px;
}

/* --- Chart Container --- */

.chart-container {
    width: 100%;
    height: 100%;
    position: relative;
}

.chart-container canvas {
    width: 100% !important;
    height: 100% !important;
}

/* --- Data Table --- */

.data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.data-table th {
    text-align: left;
    padding: 10px 14px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    border-bottom: 2px solid var(--color-border);
}

.data-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
}

.data-table tbody tr:hover {
    background: var(--color-surface-hover);
}

/* --- Gauge --- */

.gauge-container {
    text-align: center;
}

.gauge-value {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
}

.gauge-bar {
    width: 100%;
    height: 8px;
    background: var(--color-border);
    border-radius: 4px;
    margin-top: 12px;
    overflow: hidden;
}

.gauge-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    border-radius: 4px;
    transition: width 0.8s ease;
}

/* --- Footer --- */

.dashboard-footer {
    text-align: center;
    padding: 16px;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    border-top: 1px solid var(--color-border);
}
