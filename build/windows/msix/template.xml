<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="compozah.exe"
        Arguments=""
        InstallLocation="C:\Program Files\github.com/d3uceY\Compozah">
    </Installer>
    <PackageInformation
        PackageName="Compozah"
        PackageDisplayName="Compozah"
        PublisherName="CN=github.com/d3uceY"
        PublisherDisplayName="github.com/d3uceY"
        Version="0.1.0.0"
        PackageDescription="A Compozah application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.example.compozah"
                Description="A Compozah application"
                DisplayName="Compozah"
                ExecutableName="compozah.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Compozah</DisplayName>
            <PublisherDisplayName>github.com/d3uceY</PublisherDisplayName>
            <Description>A Compozah application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="compozah.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
